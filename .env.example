
BACKEND_PORT= 
FRONTEND_PORT= 
FRONTEND_ORIGIN= 
MONGODB_URI= 
REDIS_URL=redis://localhost:6379
# Genera un secreto largo y aleatorio. No reutilices este placeholder.
JWT_SECRET=REEMPLAZAR_CON_SECRETO_ALEATORIO_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRES_IN=1d

# Market provider
MARKET_PROVIDER=mock
SIMULATION_STRATEGY=flat
MARKET_HOURS_OPEN=09:30
MARKET_HOURS_CLOSED=16:00
MARKET_FETCH_ON_STARTUP=false
MARKET_TICK_INTERVAL_SECONDS=5
INITIAL_BALANCE=100000
COMMISSION_RATE=0.005

# Mock provider
MOCK_DAILY_REFRESH_CRON=* * * * *

# Eodhd provider
EODHD_API_KEY= 
EODHD_BASE_URL=https://eodhd.com/api
EODHD_EXCHANGE_CODE=SN
EODHD_SYMBOLS=COPEC.SN,CENCOSUD.SN,CHILE.SN
EODHD_DAILY_REFRESH_ENABLED=true
EODHD_DAILY_REFRESH_CRON=0 30 18 * * 1-5
EODHD_CACHE_TTL_SECONDS=86400

# Currency Exchange Module
CURRENCY_PROVIDER=exchangeRate
CURRENCY_SIMULATION_STRATEGY=nw
CURRENCY_RT_TICK_INTERVAL_SECONDS=5
CURRENCY_ANCHOR_VOLATILITY=0.005
CURRENCY_ANCHOR_DRIFT=0

# Mock provider
MOCK_CURRENCY_SYMBOLS=USDCLP

# ExchangeRate provider
EXCHANGERATE_API_KEY=
EXCHANGERATE_BASE_URL=https://v6.exchangerate-api.com/v6
EXCHANGERATE_SYMBOLS=USDCLP,EURUSD
EXCHANGERATE_REFRESH_CRON=*/10 * * * * *
# Global currency suffix mapping (suffix=ISO, comma-separated)
CURRENCY_SUFFIX_MAP=.SN=CLP,.US=USD
